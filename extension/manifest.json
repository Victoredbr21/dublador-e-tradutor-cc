{
  "manifest_version": 3,
  "name": "Leitor de Legendas Acessível (CC)",
  "version": "0.1.0",
  "description": "Lê e narra automaticamente as legendas (Closed Captions) de vídeos na web usando TTS nativo.",
  "minimum_chrome_version": "116",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configurações do Leitor"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}